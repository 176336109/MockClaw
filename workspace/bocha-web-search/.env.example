# 博查AI Web Search API配置
# 复制此文件为.env并填写您的配置

# API密钥（必需，从 https://open.bocha.cn 获取）
BOCHA_API_KEY=your_api_key_here

# API端点（可选，默认使用官方端点）
# BOCHA_API_ENDPOINT=https://api.bocha.cn/v1/web-search

# 请求超时时间（秒，可选）
# BOCHA_REQUEST_TIMEOUT=30

# 启用调试模式（可选）
# BOCHA_DEBUG=false

# 默认输出格式（可选：text, json）
# BOCHA_DEFAULT_FORMAT=text

# 默认结果数量（1-50）
# BOCHA_DEFAULT_COUNT=10

# 默认时间过滤
# BOCHA_DEFAULT_FRESHNESS=noLimit

# 是否默认显示摘要
# BOCHA_DEFAULT_SUMMARY=false
{"type":"message","id":"83630a76","parentId":"2fb3dbb4","timestamp":"2026-02-28T04:37:35.684Z","message":{"role":"assistant","content":[{"type":"text","text":"创建OpenAPI YAML配置："},{"type":"toolCall","id":"call_00_RjmkXVebgAnSJq2jLVytv2ef","name":"write","arguments":{"path":"bocha-web-search/openapi.yaml","content":"openapi: 3.0.0\ninfo:\n  title: 博查AI Web Search API\n  description: 博查AI网页搜索API的OpenAPI规范\n  version: 1.0.0\n  contact:\n    name: 博查AI\n    url: https://open.bocha.cn\n  license:\n    name: MIT\n    url: https://opensource.org/licenses/MIT\n\nservers:\n  - url: https://api.bocha.cn/v1\n    description: 生产服务器\n\npaths:\n  /web-search:\n    post:\n      summary: 执行网页搜索\n      description: 使用博查AI Web Search API进行网页搜索\n      operationId: webSearch\n      security:\n        - BearerAuth: []\n      requestBody:\n        required: true\n        content:\n          application/json:\n            schema:\n              $ref: '#/components/schemas/SearchRequest'\n      responses:\n        '200':\n          description: 搜索成功\n          content:\n            application/json:\n              schema:\n                $ref: '#/components/schemas/SearchResponse'\n        '400':\n          description: 请求参数错误\n        '401':\n          description: 认证失败\n        '429':\n          description: 请求过于频繁\n        '500':\n          description: 服务器内部错误\n\ncomponents:\n  securitySchemes:\n    BearerAuth:\n      type: http\n      scheme: bearer\n      bearerFormat: JWT\n\n  schemas:\n    SearchRequest:\n      type: object\n      required:\n        - query\n      properties:\n        query:\n          type: string\n          description: 搜索关键词\n          example: \"OpenAI最新进展\"\n        freshness:\n          type: string\n          description: 时间过滤\n          enum: [noLimit, oneDay, oneWeek, oneMonth, oneYear]\n          default: noLimit\n          example: oneWeek\n        summary:\n          type: boolean\n          description: 是否显示摘要\n          default: false\n          example: true\n        count:\n          type: integer\n          description: 结果数量\n          minimum: 1\n          maximum: 50\n          default: 10\n          example: 10\n        include:\n          type: string\n          description: 包含特定网站\n          example: \"github.com\"\n        exclude:\n          type: string\n          description: 排除特定网站\n          example: \"baidu.com\"\n\n    SearchResult:\n      type: object\n      properties:\n        title:\n          type: string\n          description: 结果标题\n          example: \"OpenAI发布最新模型\"\n        url:\n          type: string\n          description: 结果URL\n          format: uri\n          example: \"https://example.com/article\"\n        snippet:\n          type: string\n          description: 结果摘要\n          example: \"OpenAI近日发布了最新的大型语言模型...\"\n        displayUrl:\n          type: string\n          description: 显示URL\n          example: \"example.com\"\n        datePublished:\n          type: string\n          description: 发布日期\n          format: date-time\n          example: \"2024-01-15T10:30:00Z\"\n        source:\n          type: string\n          description: 来源网站\n          example: \"Example News\"\n\n    SearchResponse:\n      type: object\n      properties:\n        query:\n          type: string\n          description: 搜索关键词\n          example: \"OpenAI最新进展\"\n        results:\n          type: array\n          description: 搜索结果列表\n          items:\n            $ref: '#/components/schemas/SearchResult'\n        summary:\n          type: string\n          description: 搜索摘要\n          example: \"关于OpenAI最新进展的搜索摘要...\"\n        metadata:\n          type: object\n          properties:\n            count:\n              type: integer\n              description: 结果数量\n              example: 10\n            freshness:\n              type: string\n              description: 使用的时间过滤\n              example: \"oneWeek\"\n            timestamp:\n              type: string\n              description: 搜索时间戳\n              format: date-time\n              example: \"2024-01-15T12:00:00Z\"\n\ntags:\n  - name: Search\n    description: 搜索相关操作"}}],"api":"openai-completions","provider":"deepseek","model":"deepseek-chat","usage":{"input":39,"output":970,"cacheRead":15744,"cacheWrite":0,"totalTokens":16753,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772253424493}}
